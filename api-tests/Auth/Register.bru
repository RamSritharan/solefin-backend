meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "owner@solefin.test",
    "password": "Password123!",
    "name": "Sole Owner",
    "businessName": "Sole Owner Consulting"
  }
}

script:post-response {
  if (res.getStatus() < 300 && res.getBody() && res.getBody().token) {
    bru.setEnvVar("token", res.getBody().token);
  }
}

tests {
  test("status is 201", function () {
    expect(res.getStatus()).to.equal(201);
  });
  test("returns a token", function () {
    expect(res.getBody().token).to.be.a("string");
  });
}
