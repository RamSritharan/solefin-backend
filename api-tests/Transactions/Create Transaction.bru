meta {
  name: Create Transaction
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/transactions
  body: json
  auth: inherit
}

body:json {
  {
    "accountId": "{{accountId}}",
    "categoryId": "{{categoryId}}",
    "amount": 49.99,
    "type": "expense",
    "date": "2026-06-24",
    "description": "Monthly SaaS subscription",
    "notes": "Annual plan billed monthly",
    "isRecurring": true
  }
}

docs {
  type is one of: income, expense. categoryId is optional.
}

script:post-response {
  if (res.getStatus() < 300 && res.getBody() && res.getBody().transaction) {
    bru.setEnvVar("transactionId", res.getBody().transaction.id);
  }
}
