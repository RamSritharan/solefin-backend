meta {
  name: Create Account
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Business Checking",
    "type": "checking",
    "balance": 5000,
    "currency": "USD"
  }
}

docs {
  type is one of: checking, savings, credit_card, cash
}

script:post-response {
  if (res.getStatus() < 300 && res.getBody() && res.getBody().account) {
    bru.setEnvVar("accountId", res.getBody().account.id);
  }
}
